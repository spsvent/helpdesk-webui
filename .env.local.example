# Azure AD App Registration
# See AZURE_AD_SETUP.md for instructions

NEXT_PUBLIC_CLIENT_ID=your-client-id-here
NEXT_PUBLIC_TENANT_ID=f0db97c1-2010-4d0c-826e-d6e0f2b25f2f

# SharePoint Configuration
NEXT_PUBLIC_SHAREPOINT_SITE_ID=skyparksv.sharepoint.com,site-id-here
NEXT_PUBLIC_TICKETS_LIST_ID=tickets-list-id-here
NEXT_PUBLIC_COMMENTS_LIST_ID=comments-list-id-here

# Approval Workflow Configuration
# Get the Group ID from Azure Portal > Azure Active Directory > Groups > [Your Group] > Object ID
NEXT_PUBLIC_GENERAL_MANAGERS_GROUP_ID=your-general-managers-group-id-here

# App URL (used for email action button links)
NEXT_PUBLIC_APP_URL=https://tickets.spsvent.net

# CDW (Campaign & Creative Development Worksheet) form module
# Create the CDW list first (admin "Set up CDW" action calls ensureCdwList, or create
# it manually), then put its list id here. Leave blank to disable the CDW UI.
NEXT_PUBLIC_CDW_LIST_ID=
# Entra group whose members may create CDWs (e.g. the marketing/creative team). Admins
# always can. Leave blank to allow any signed-in user; set it to lock creation down to
# that group.
NEXT_PUBLIC_CDW_REQUESTERS_GROUP_ID=
# Azure Functions for CDW email approval (deployed in the same helpdesk-notify-func app)
NEXT_PUBLIC_CDW_APPROVAL_ACTION_URL=https://helpdesk-notify-func-d9ephvfxgaavhdg6.westus2-01.azurewebsites.net/api/cdwapprovalaction
NEXT_PUBLIC_SEND_CDW_APPROVAL_REQUEST_URL=https://helpdesk-notify-func-d9ephvfxgaavhdg6.westus2-01.azurewebsites.net/api/sendcdwapprovalrequest

# Purchase Request form module
# Create the PurchaseRequests list first (admin "Set up Purchase list" action calls
# ensurePurchaseList), then put its id here. Leave blank to disable the purchase UI.
NEXT_PUBLIC_PURCHASE_LIST_ID=
# Order Catalog (recurring order sheets): master list of standard reorder items.
# Create the OrderCatalog list first (admin action calls ensureOrderCatalogList),
# then put its id here. Leave blank to disable the recurring order-sheet UI.
NEXT_PUBLIC_ORDER_CATALOG_LIST_ID=
# Notification Opt-Out: emails on this list get NO help desk notifications while
# keeping full app access/roles. Create the NotificationOptOut list (Settings →
# Notification Opt-Out can create it), then put its id here. Also set the same id
# as NOTIFICATION_OPTOUT_LIST_ID on the helpdesk-notify-func Function App so the
# server-side send paths enforce it. Leave blank to disable the feature.
NEXT_PUBLIC_NOTIFICATION_OPTOUT_LIST_ID=
NEXT_PUBLIC_PURCHASE_APPROVAL_ACTION_URL=https://helpdesk-notify-func-d9ephvfxgaavhdg6.westus2-01.azurewebsites.net/api/purchaseapprovalaction
NEXT_PUBLIC_SEND_PURCHASE_APPROVAL_REQUEST_URL=https://helpdesk-notify-func-d9ephvfxgaavhdg6.westus2-01.azurewebsites.net/api/sendpurchaseapprovalrequest

# HEIC → JPEG converter function (deployed in the same helpdesk-notify-func app).
# Enables inline preview of HEIC/HEIF photos (iPhone) that Chrome/Firefox can't
# decode. Leave blank to disable — HEIC then falls back to a download-only tile.
NEXT_PUBLIC_HEIC_CONVERT_URL=https://helpdesk-notify-func-d9ephvfxgaavhdg6.westus2-01.azurewebsites.net/api/convertheic
